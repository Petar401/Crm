# Supabase — get these from your project's API settings (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the browser. Used for privileged server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Google Gemini API key for AI actions. Leave blank to disable AI features.
GEMINI_API_KEY=
