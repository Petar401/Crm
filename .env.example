# Supabase — get these from your project's API settings (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL of the deployed app, used to build auth redirect links
# (e.g. the password-reset callback). Must match a Supabase Redirect URL.
# Leave blank locally to default to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Server-only. NEVER expose to the browser. Used for privileged server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Groq API key for AI actions (get one free at https://console.groq.com).
# Leave blank to disable AI features.
GROQ_API_KEY=

# Server-only. Shared secret protecting the scheduled lead-discovery route
# (/api/cron/leads). Generate a random string and use the same value in the
# Supabase pg_cron job (see supabase/migrations/0011_lead_automation.sql).
CRON_SECRET=
